{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "_meta": {
    "name": "JR Academy / 匠人学院 — Design Tokens (Master Brand)",
    "version": "4.1.0",
    "owner": "JR Academy",
    "tagline": "学 AI 来匠人 · STUDY AI AT JR ACADEMY",
    "subSlogan": "一起成为 AI 时代的匠人 · Be an AI Craftsman.",
    "subtitle": "系统化 AI 学习与职业成长平台，陪你从入门到精通，用 AI 改变未来。",
    "mascot": "牛小匠 · 黑色 + 墨镜 · JR 标识",
    "mascotRole": "AI 学习伙伴 / 职业成长陪伴官",
    "grid": "4pt",
    "fontCN": "思源黑体 / Source Han Sans",
    "fontEN": "Inter",
    "source": "index.html Brand Board 13 panels (2026-05-24)",
    "subProducts": ["unimate-ai", "cert-master", "job-hunter"]
  },
  "color": {
    "primary": {
      "dark":   { "$value": "#0D0F12", "$type": "color", "$description": "主色 Dark — 主 CTA / Logo / Brand 主标识" }
    },
    "accent": {
      "red":    { "$value": "#FF4D4F", "$type": "color", "$description": "强调色 Red — Danger / 强调 / 错题" },
      "redAA":  { "$value": "#D92D20", "$type": "color", "$description": "可访问红底 — 白色小字 AA，用于编号胶囊 / 小面积错误 icon" },
      "redText": { "$value": "#B42318", "$type": "color", "$description": "可访问红字 — 用于浅红底 / 暖白底上的小字" },
      "purple": { "$value": "#7B61FF", "$type": "color", "$description": "紫色 Purple — AI / 学习进度 / 高级" },
      "yellow": { "$value": "#FFC84D", "$type": "color", "$description": "黄色 Yellow — 警告 / 成就 / 提醒" },
      "green":  { "$value": "#22C55E", "$type": "color", "$description": "绿色 Green — Success / 完成" }
    },
    "neutral": {
      "900": { "$value": "#1F2937", "$type": "color", "$description": "中性 900 — 主文字" },
      "600": { "$value": "#6B7280", "$type": "color", "$description": "中性 600 — 次正文 / 副标" },
      "300": { "$value": "#D1D5DB", "$type": "color", "$description": "中性 300 — 边框 / divider / disabled" },
      "100": { "$value": "#F3F4F6", "$type": "color", "$description": "中性 100 — 浅灰 bg / input bg" },
      "50":  { "$value": "#FAFAFA", "$type": "color", "$description": "中性 50  — 页面默认 bg" },
      "white": { "$value": "#FFFFFF", "$type": "color", "$description": "白色 — 卡片 / 模态" }
    },
    "surface": {
      "canvas": { "$value": "#FFFCF6", "$type": "color", "$description": "Brand Board 页面暖白底，AI 写主品牌页面默认背景" },
      "panel": { "$value": "#FFFDF8", "$type": "color", "$description": "Brand Board 面板 / 卡片暖白底" },
      "panelAlt": { "$value": "#FFFBF1", "$type": "color", "$description": "轻微区分的暖白区块底" },
      "border": { "$value": "#F3D8B5", "$type": "color", "$description": "浅橙细边，主品牌卡片默认边框" },
      "borderStrong": { "$value": "#EFC98F", "$type": "color", "$description": "hover / selected 的暖橙边" },
      "divider": { "$value": "#F0E2CF", "$type": "color", "$description": "暖色 divider" }
    },
    "wash": {
      "red":    { "$value": "#FEE2E2", "$type": "color", "$description": "红 wash — 重要 chip / danger alert" },
      "purple": { "$value": "#EFEBFF", "$type": "color", "$description": "紫 wash — AI chip / info alert" },
      "yellow": { "$value": "#FFF6DA", "$type": "color", "$description": "黄 wash — 警告 alert / 高亮" },
      "green":  { "$value": "#DCFCE7", "$type": "color", "$description": "绿 wash — success alert / 完成" }
    },
    "semantic": {
      "success": { "$value": "{color.accent.green}",  "$type": "color" },
      "warning": { "$value": "{color.accent.yellow}", "$type": "color" },
      "danger":  { "$value": "{color.accent.red}",    "$type": "color" },
      "info":    { "$value": "{color.accent.purple}", "$type": "color", "$description": "用紫不用蓝（v4 去掉蓝色）" }
    },
    "logoGradient": {
      "boxOrange": { "$value": "#FF7E3B", "$type": "color", "$description": "JR Box 渐变起点 — 仅 logo 用" },
      "boxPink":   { "$value": "#FF3B6F", "$type": "color", "$description": "JR Box 渐变终点 — 仅 logo 用" }
    }
  },
  "radius": {
    "none": { "$value": "0",     "$type": "dimension" },
    "xs":   { "$value": "4px",   "$type": "dimension" },
    "sm":   { "$value": "8px",   "$type": "dimension", "$description": "Button / Input / Product Card 默认" },
    "md":   { "$value": "12px",  "$type": "dimension", "$description": "少量大输入框 / 紧凑面板" },
    "lg":   { "$value": "16px",  "$type": "dimension", "$description": "Brand Board 大面板默认" },
    "xl":   { "$value": "20px",  "$type": "dimension" },
    "2xl":  { "$value": "24px",  "$type": "dimension", "$description": "Hero / Modal" },
    "3xl":  { "$value": "32px",  "$type": "dimension" },
    "4xl":  { "$value": "40px",  "$type": "dimension" },
    "full": { "$value": "9999px","$type": "dimension", "$description": "Pill / avatar / chip" }
  },
  "spacing": {
    "1":  { "$value": "4px",   "$type": "dimension" },
    "2":  { "$value": "8px",   "$type": "dimension" },
    "3":  { "$value": "12px",  "$type": "dimension" },
    "4":  { "$value": "16px",  "$type": "dimension" },
    "6":  { "$value": "24px",  "$type": "dimension" },
    "8":  { "$value": "32px",  "$type": "dimension" },
    "10": { "$value": "40px",  "$type": "dimension" },
    "12": { "$value": "48px",  "$type": "dimension" },
    "14": { "$value": "56px",  "$type": "dimension" },
    "16": { "$value": "64px",  "$type": "dimension" },
    "20": { "$value": "80px",  "$type": "dimension" },
    "24": { "$value": "96px",  "$type": "dimension" },
    "32": { "$value": "128px", "$type": "dimension" }
  },
  "layout": {
    "containerMobile":  { "$value": "375px",  "$type": "dimension" },
    "containerTablet":  { "$value": "768px",  "$type": "dimension" },
    "containerDesktop": { "$value": "1200px", "$type": "dimension" },
    "containerWide":    { "$value": "1440px", "$type": "dimension" }
  },
  "shadow": {
    "none":     { "$value": "none",                             "$type": "shadow" },
    "sm":       { "$value": "0 1px 2px rgba(13,15,18,0.04)",    "$type": "shadow", "$description": "轻 / inline" },
    "md":       { "$value": "0 4px 12px rgba(13,15,18,0.08)",   "$type": "shadow", "$description": "Card 默认" },
    "lg":       { "$value": "0 8px 24px rgba(13,15,18,0.10)",   "$type": "shadow", "$description": "中等 / hover" },
    "xl":       { "$value": "0 12px 28px rgba(13,15,18,0.12)",  "$type": "shadow", "$description": "Modal / 浮显" },
    "blackGlow":{ "$value": "0 8px 20px rgba(13,15,18,0.28)",   "$type": "shadow", "$description": "Primary CTA 发光" },
    "panel": { "$value": "0 10px 28px rgba(13,15,18,0.06)", "$type": "shadow", "$description": "Brand Board 面板轻阴影" }
  },
  "component": {
    "button": {
      "primaryBg": { "$value": "{color.primary.dark}", "$type": "color", "$description": "主按钮必须黑底" },
      "primaryText": { "$value": "#FFFFFF", "$type": "color" },
      "primaryHover": { "$value": "#24272D", "$type": "color" },
      "radius": { "$value": "{radius.sm}", "$type": "dimension" }
    },
    "panel": {
      "background": { "$value": "{color.surface.panel}", "$type": "color" },
      "border": { "$value": "{color.surface.border}", "$type": "color" },
      "radius": { "$value": "{radius.lg}", "$type": "dimension" },
      "shadow": { "$value": "{shadow.panel}", "$type": "shadow" }
    },
    "card": {
      "background": { "$value": "{color.surface.panel}", "$type": "color" },
      "border": { "$value": "{color.surface.border}", "$type": "color" },
      "radius": { "$value": "{radius.sm}", "$type": "dimension" }
    },
    "chipAI": {
      "background": { "$value": "#F1EEFF", "$type": "color" },
      "border": { "$value": "#D6CEFF", "$type": "color" },
      "text": { "$value": "#3F2BA8", "$type": "color" }
    },
    "focus": {
      "ring": { "$value": "rgba(123,97,255,0.22)", "$type": "color" }
    },
    "icon": {
      "size":    { "$value": "24px",         "$type": "dimension", "$description": "lucide 默认 viewBox 0 0 24 24" },
      "sizeSm":  { "$value": "18px",         "$type": "dimension", "$description": "小尺寸 — 用于 pill/tag/inline" },
      "sizeLg":  { "$value": "32px",         "$type": "dimension", "$description": "大尺寸 — 用于 hero/feature" },
      "stroke":  { "$value": "2",            "$type": "number",    "$description": "SVG stroke-width 单位" },
      "color":   { "$value": "currentColor", "$type": "color",     "$description": "继承父级文字色" },
      "radius":  { "$value": "4px",          "$type": "dimension", "$description": "方形 icon 内圆角（round 变体单独 50%）" }
    }
  },
  "font": {
    "family": {
      "sans": {
        "$value": "'Inter', 'Source Han Sans SC', '思源黑体', 'PingFang SC', 'Microsoft YaHei', system-ui, -apple-system, sans-serif",
        "$type": "fontFamily",
        "$description": "v4: 英文 Inter / 中文 思源黑体"
      },
      "mono": {
        "$value": "'JetBrains Mono', 'SF Mono', Menlo, Consolas, monospace",
        "$type": "fontFamily"
      }
    },
    "size": {
      "h1":       { "$value": "32px", "$type": "dimension", "$description": "标题 1 — Bold（v4: 36→32）" },
      "h2":       { "$value": "24px", "$type": "dimension", "$description": "标题 2 — Bold" },
      "h3":       { "$value": "18px", "$type": "dimension", "$description": "标题 3 — Semibold（v4: 20→18）" },
      "body":     { "$value": "14px", "$type": "dimension", "$description": "正文 — Regular（v4: 16→14）" },
      "caption":  { "$value": "12px", "$type": "dimension", "$description": "辅助 / metadata" },
      "btnLg":    { "$value": "16px", "$type": "dimension", "$description": "大按钮 - Bold" },
      "btnMd":    { "$value": "14px", "$type": "dimension", "$description": "中按钮 - Medium" }
    },
    "weight": {
      "regular":  { "$value": "400", "$type": "fontWeight" },
      "medium":   { "$value": "500", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" },
      "bold":     { "$value": "700", "$type": "fontWeight" }
    },
    "lineHeight": {
      "heading": { "$value": "1.3", "$type": "number" },
      "body":    { "$value": "1.6", "$type": "number" }
    }
  },
  "motion": {
    "duration": {
      "fast":   { "$value": "120ms", "$type": "duration" },
      "base":   { "$value": "200ms", "$type": "duration" },
      "slow":   { "$value": "320ms", "$type": "duration" }
    },
    "easing": {
      "standard": { "$value": "cubic-bezier(0.2, 0.8, 0.2, 1)",   "$type": "cubicBezier" },
      "spring":   { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier" }
    }
  },
  "mascot": {
    "expressions": [
      "happy",
      "thinking",
      "studying",
      "sprint",
      "teaching",
      "celebration"
    ],
    "_note": "v4: 6 个标准表情。原 11 视图 + 8 动作扩展库见 assets/mascot/。"
  },
  "featurePills": {
    "courseStructured":   "体系化课程 · 系统学习路径",
    "projectPractice":    "AI 实战项目 · 学以致用",
    "careerEmpower":      "职业赋能 · 能力进阶",
    "growthCompanion":    "陪伴式成长 · 社群与教练"
  }
}
